---
import Base from '../layouts/Base.astro';
---

<Base title="Not Found">
  <div class="py-24 text-center">
    <p class="font-mono text-bc-gold text-sm tracking-widest uppercase mb-4">404</p>
    <h1 class="font-display text-5xl text-bc-white mb-6">Post not found</h1>
    <a href="/" class="font-mono text-sm text-bc-gold hover:text-bc-white transition-colors">
      ← Back to all posts
    </a>
  </div>
</Base>
